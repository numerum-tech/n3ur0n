# /etc/n3ur0n/seed.env — sourced by n3ur0n-seed.service
# Copy to /etc/n3ur0n/seed.env and edit.

N3UR0N_CONFIG_DIR=/var/lib/n3ur0n
N3UR0N_PORT=4242

# Public URL peers will use (after certbot / nginx)
N3UR0N_ENDPOINT=https://seed.n3ur0n.net

# Optional: first-hop peers (comma-separated). Leave empty for the seed itself.
# N3UR0N_BOOTSTRAP_PEERS=

# Minimal seed can stay on echo; switch when you publish real caps.
# N3UR0N_BACKEND=echo
# Or manifest mode:
# N3UR0N_MANIFEST_DIR=/var/lib/n3ur0n/manifests

# Seed usually has no planner (peers invoke caps; they plan locally).
# N3UR0N_PLANNER_MODE=none
